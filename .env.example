# PostgreSQL (used by Docker Compose service `db`)
POSTGRES_USER=garden_user
POSTGRES_PASSWORD=garden_secret
POSTGRES_DB=garden_db

# FastAPI backend
DATABASE_URL=postgresql://garden_user:garden_secret@db:5432/garden_db
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cookie security (set COOKIE_SECURE=true behind HTTPS in production)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Frontend (local dev outside Docker)
VITE_API_URL=http://localhost:8000
